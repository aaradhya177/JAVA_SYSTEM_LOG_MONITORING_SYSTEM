# Database Configuration for Render

# Copy this file content to Render Environment Variables

# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/logmonitor
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD

# How to get these values:
# 1. Go to Render Dashboard
# 2. Click on your PostgreSQL service
# 3. Find "External Database URL" - that's DATABASE_URL
# 4. Extract username, password, host, and port
# 5. Set DB_USER and DB_PASSWORD accordingly

# Example External URL conversion:
# Render gives: postgresql://user:pass@host.com:5432/logmonitor
# Set DATABASE_URL: postgresql://user:pass@host.com:5432/logmonitor
# Set DB_USER: user
# Set DB_PASSWORD: pass

# Local Development (default)
# DATABASE_URL=jdbc:postgresql://localhost:5432/logmonitor
# DB_USER=postgres
# DB_PASSWORD=postgres
